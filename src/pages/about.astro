---
import Base from '../layouts/Base.astro';
---
<Base title="About" description="About WriteNow Media — author, researcher, publisher.">
  <div class="hero" style="padding-bottom:2rem;">
    <div class="wrap">
      <span class="eyebrow">About</span>
      <h1>The person behind <span class="marked">the byline</span>.</h1>
    </div>
  </div>
  <section style="padding-top:1rem;">
    <div class="wrap prose">
      <p>
        <!-- Replace with your real bio -->
        WriteNow Media is the practice of [Your Name] — author, researcher, and
        publisher. After [N] years writing for [industries / publications], the
        work settled into a single conviction: good writing is a research
        problem before it is a language problem.
      </p>
      <p>
        Clients come here for three reasons. Businesses need someone who can
        read a spec sheet and interview an engineer, then explain the product
        in plain English. Families need someone who can read a census schedule,
        a ship manifest, and a parish register, then turn names into people.
        And authors need a collaborator who has been through the publishing
        process and knows where the manuscripts go to die.
      </p>
      <h2>Credentials</h2>
      <ul>
        <li>Published author: [titles]</li>
        <li>[Professional memberships — APG, ASJA, etc.]</li>
        <li>[Notable publications or clients]</li>
      </ul>
      <p style="margin-top:2rem;"><a class="btn" href="/contact/">Work together</a></p>
    </div>
  </section>
</Base>
