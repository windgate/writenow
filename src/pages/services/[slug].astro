---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(s => ({ params: { slug: s.id }, props: { entry: s } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title} description={entry.data.tagline}>
  <div class="hero" style="padding-bottom:2rem;">
    <div class="wrap">
      <span class="eyebrow">Service</span>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.tagline}</p>
    </div>
  </div>
  <section style="padding-top:1rem;">
    <div class="wrap prose">
      <Content />
      {entry.data.deliverables.length > 0 && (
        <>
          <h3 style="margin-top:2.5rem;">Typical deliverables</h3>
          <ul class="deliverables">
            {entry.data.deliverables.map(d => <li>{d}</li>)}
          </ul>
        </>
      )}
      <p style="margin-top:2.5rem;"><a class="btn" href="/contact/">Discuss your project</a></p>
    </div>
  </section>
</Base>
