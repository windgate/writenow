---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(p => ({ params: { slug: p.id }, props: { entry: p } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title} description={entry.data.excerpt}>
  <div class="hero" style="padding-bottom:2rem;">
    <div class="wrap">
      <span class="eyebrow">{entry.data.pubDate.toDateString()}</span>
      <h1>{entry.data.title}</h1>
    </div>
  </div>
  <section style="padding-top:1rem;">
    <div class="wrap prose">
      <Content />
    </div>
  </section>
</Base>
