---
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = 'Research-driven writing for business, technology, history, and family legacy.' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} · WriteNow Media</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={new URL('/og.png', Astro.site)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
  <link rel="alternate" type="application/rss+xml" title="WriteNow Media" href="/rss.xml" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'WriteNow Media',
    url: 'https://writenow.media',
    description: 'Research and writing services: business and technology writing, history and genealogy, books, biographies, and newsletters.',
  })} />
</head>
<body>
  <header class="site">
    <div class="wrap">
      <nav aria-label="Main">
        <a class="logo" href="/" aria-label="WriteNow Media home">
          <img src="/wnm-logo.png" alt="WriteNow Media" width="225" height="47" style="display:block; height:2.6rem; width:auto;" />
        </a>
        <a href="/services/">Services</a>
        <a href="/successes/">Successes</a>
        <a href="/process/">Process</a>
        <a href="/blog/">Notes</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site">
    <div class="wrap">
      <p class="eyebrow">WriteNow Media · Research · Writing · Publishing</p>
      <p style="margin-top:.6rem;">Every good story begins with the record. © {new Date().getFullYear()} WriteNow Media.</p>
    </div>
  </footer>
</body>
</html>
